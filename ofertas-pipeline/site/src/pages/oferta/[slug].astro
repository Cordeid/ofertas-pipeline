---
import Layout from '../../layouts/Layout.astro';
import ofertas from '../../data/ofertas.json';

export function getStaticPaths() {
  return ofertas.map((oferta) => ({
    params: { slug: oferta.slug },
    props: { oferta },
  }));
}

interface Oferta {
  slug: string;
  titulo: string;
  preco: string;
  imagem_url: string | null;
  descricao: string;
  obs: string | null;
  link_afiliado: string;
  data: string;
}

const { oferta } = Astro.props as { oferta: Oferta };

function formatarData(iso: string) {
  return new Date(iso).toLocaleDateString('pt-BR', {
    day: '2-digit', month: 'long', year: 'numeric',
  });
}
---

<Layout
  title={`${oferta.titulo} — Ofertas Verificadas`}
  description={oferta.descricao}
>
  <div class="container">
    <a href="/" class="voltar">← Voltar às ofertas</a>

    <!-- Banner de oferta encerrada (oculto por padrão, ativado pelo JS) -->
    <div id="banner-encerrada" class="banner-encerrada" style="display:none">
      <span>⏰ Oferta encerrada — preço válido em {formatarData(oferta.data)}, pode ter mudado.</span>
      <a href="/" class="ver-ativas">Ver ofertas ativas →</a>
    </div>

    <article class="oferta" data-ts={oferta.data}>
      {oferta.imagem_url && (
        <div class="imagem">
          <img
            src={oferta.imagem_url}
            alt={oferta.titulo}
            onerror="this.parentElement.innerHTML='📦';this.parentElement.classList.add('placeholder');"
          />
        </div>
      )}

      <div class="conteudo">
        <h1>{oferta.titulo}</h1>

        <p class="preco">R$ {oferta.preco}</p>

        {oferta.obs && (
          <p class="obs">✅ {oferta.obs}</p>
        )}

        <p class="descricao">{oferta.descricao}</p>

        <div class="cta-wrapper">
          <a
            id="btn-cta"
            href={oferta.link_afiliado}
            class="cta"
            rel="sponsored nofollow noopener"
            target="_blank"
          >
            Ver na Amazon →
          </a>
          <p class="disclaimer-inline">Você paga exatamente o mesmo preço — a comissão sai da Amazon, não do seu bolso.</p>
        </div>

        <p class="data-verificado">Preço verificado em {formatarData(oferta.data)}</p>
      </div>
    </article>
  </div>
</Layout>

<script>
  const LIMITE_MS = 48 * 60 * 60 * 1000;
  const artigo = document.querySelector<HTMLElement>('article.oferta');
  const banner = document.getElementById('banner-encerrada');
  const btnCta = document.getElementById('btn-cta');

  if (artigo?.dataset.ts) {
    const idade = Date.now() - new Date(artigo.dataset.ts).getTime();
    if (idade >= LIMITE_MS) {
      if (banner) banner.style.display = 'flex';
      if (btnCta) btnCta.textContent = 'Ver preço atual na Amazon →';
    }
  }
</script>

<style>
  .container {
    max-width: 700px;
    margin: 0 auto;
  }

  .voltar {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--cor-texto-suave);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .voltar:hover { color: var(--cor-destaque); }

  .banner-encerrada {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    background: #fff8e1;
    border: 1px solid #f5c542;
    border-radius: var(--raio);
    padding: 0.9rem 1.1rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
    color: #5a4200;
  }

  .ver-ativas {
    color: var(--cor-destaque);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .ver-ativas:hover { text-decoration: underline; }

  .oferta {
    background: var(--cor-card);
    border: 1px solid var(--cor-borda);
    border-radius: var(--raio);
    box-shadow: var(--sombra);
    overflow: hidden;
  }

  .imagem {
    width: 100%;
    max-height: 380px;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .imagem img {
    width: 100%;
    max-height: 380px;
    object-fit: contain;
  }

  .imagem.placeholder {
    height: 200px;
    font-size: 3.5rem;
    color: #bbb;
  }

  .conteudo {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  h1 {
    font-size: 1.35rem;
    line-height: 1.4;
  }

  .preco {
    font-size: 2rem;
    font-weight: 800;
    color: var(--cor-destaque);
  }

  .obs {
    background: #edf7ed;
    border: 1px solid #b5dfb5;
    color: #2a6b2a;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .descricao {
    color: var(--cor-texto-suave);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .cta-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cta {
    display: block;
    background: var(--cor-destaque);
    color: #fff;
    text-align: center;
    padding: 0.85rem 1.5rem;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }

  .cta:hover { background: var(--cor-destaque-hover); }

  .disclaimer-inline {
    font-size: 0.78rem;
    color: var(--cor-texto-suave);
    text-align: center;
    line-height: 1.4;
  }

  .data-verificado {
    font-size: 0.78rem;
    color: #aaa;
    margin-top: 0.25rem;
  }
</style>
